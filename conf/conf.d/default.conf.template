server {
  listen 8080;
  port_in_redirect off;

  location /_health {
    access_log off;
    add_header 'Content-Type' 'application/json';
    return 200 '{"status":"Ok"}';
  }
  location ^~ /cms/cookie-manager/dashboard {
    alias /usr/share/nginx/html;
    try_files $uri $uri/ /cms/cookie-manager/dashboard/index.html;

      add_header Content-Security-Policy "default-src 'self' https://storage.googleapis.com https://s3.ap-south-1.amazonaws.com https://*.idfystaging.com https://insights.shared.idfy.com https://insights.shared.idfystaging.com https://*.idfy.com wss://*.idfystaging.com wss://*.idfy.com https://*.idfystorage.com data: blob: https://cdnjs.cloudflare.com/ajax/libs/lamejs/1.2.0/lame.min.js; img-src 'self' https://storage.googleapis.com https://s3.ap-south-1.amazonaws.com https://*.idfystaging.com https://*.idfy.com https://*.idfystorage.com data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com; object-src 'none'; style-src-attr 'unsafe-inline'" always;
      add_header X-Content-Type-Options "nosniff" always;
      add_header X-Frame-Options "SAMEORIGIN" always;
      add_header Referrer-Policy "strict-origin-when-cross-origin" always;
      add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
      add_header Cross-Origin-Opener-Policy "same-origin" always;
      add_header Cache-Control "private, no-cache, no-store, max-age=0" always;
      add_header Expires "Sat, 01 Jan 2000 00:00:00 GMT" always;
  }
  location / {
    root   /usr/share/nginx/html;
    index  index.html index.htm;
    try_files $uri $uri/ /cms/cookie-manager/dashboard/index.html;
  }
  error_page 403 404 405 406 407 408 409 410 411 412 413 414 415 416 417 421 422 423 424 426 428 429 431 451 500 501 502 503 504 505 506 507 508 510 511 /error.html;
  location = /error.html {
    root   /usr/share/nginx/html;
  }
}
